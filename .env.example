# TerraNeuron Platform Environment Variables

# ============================================================
# OPTIONAL: Cloud LLM Configuration (Terra-Cortex Hybrid AI)
# ============================================================
OPENAI_API_KEY=ollama
OPENAI_MODEL=llama3.1
OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# ============================================================
# Database Credentials (Optional Override)
# ============================================================
# MYSQL_ROOT_PASSWORD=root
# MYSQL_DATABASE=terra_ops
# MYSQL_USER=terra
# MYSQL_PASSWORD=terra2025

# ============================================================
# Redis Configuration
# ============================================================
# Shared by Terra-Gateway and Terra-Sense command/device-state registries.
REDIS_PASSWORD=terra2025

# Device state must remain in Redis longer than the freshness window.
DEVICE_STATE_FRESHNESS_SECONDS=120
DEVICE_STATE_TTL_SECONDS=600

# ============================================================
# Security Configuration
# ============================================================
# User-facing Terra-Ops JWT. Replace before non-local use.
JWT_SECRET=DEMO_ONLY_CHANGE_ME_LOCAL_JWT_SECRET_32_CHARS_MIN

# Cortex -> Ops crop-read service JWT. Independent from user JWT.
SERVICE_AUTH_JWT_SECRET=DEMO_ONLY_CHANGE_ME_CORTEX_OPS_SERVICE_KEY_32_CHARS

# Ops -> Sense device-safety service JWT. Do not reuse either key above.
DEVICE_SAFETY_JWT_SECRET=DEMO_ONLY_CHANGE_ME_DEVICE_SAFETY_KEY_32_CHARS

# Explicit browser origins only; wildcard is rejected.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================
# Kafka / Cortex Reliability (Optional Override)
# ============================================================
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# KAFKA_EVENT_DEDUPE_RETENTION_DAYS=30
# KAFKA_EVENT_DEDUPE_SWEEP_INTERVAL_SECONDS=300
# CORTEX_FATAL_TASK_EXIT_DELAY_SECONDS=5

# ============================================================
# Usage
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Replace JWT_SECRET, SERVICE_AUTH_JWT_SECRET, DEVICE_SAFETY_JWT_SECRET,
#    and REDIS_PASSWORD before any shared or production deployment.
# 3. Keep DEVICE_STATE_TTL_SECONDS greater than DEVICE_STATE_FRESHNESS_SECONDS.
# 4. Start services: docker compose up -d
