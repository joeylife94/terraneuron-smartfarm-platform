{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Control Command Event - CloudEvents v1.0",
  "description": "Command request published by terra-ops to the terra.control.command Kafka topic for terra-sense",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "datacontenttype",
    "data"
  ],
  "properties": {
    "specversion": { "type": "string", "const": "1.0" },
    "type": { "type": "string", "const": "terra.ops.command.execute" },
    "source": { "type": "string", "const": "//terraneuron/terra-ops" },
    "id": { "type": "string", "format": "uuid" },
    "time": { "type": "string", "format": "date-time" },
    "datacontenttype": { "type": "string", "const": "application/json" },
    "data": {
      "type": "object",
      "required": [
        "trace_id",
        "plan_id",
        "command_id",
        "farm_id",
        "target_asset_id",
        "action_type",
        "parameters",
        "executed_by"
      ],
      "properties": {
        "trace_id": {
          "type": "string",
          "description": "Distributed trace identifier inherited from the action plan"
        },
        "plan_id": {
          "type": "string",
          "description": "Action plan that authorized this command"
        },
        "command_id": {
          "type": "string",
          "pattern": "^cmd-[a-f0-9-]{8,36}$",
          "description": "Unique command identifier generated by terra-ops"
        },
        "farm_id": {
          "type": "string",
          "description": "Farm used for device routing and Kafka message partitioning"
        },
        "target_asset_id": {
          "type": "string",
          "description": "Device that should execute the command"
        },
        "target_asset_type": {
          "type": "string",
          "description": "Explicit asset classification. Optional only for command outbox rows created before the device-safety rollout."
        },
        "action_category": {
          "type": "string",
          "enum": ["ventilation", "irrigation", "lighting", "heating", "cooling", "alert"],
          "description": "Explicit action category. Optional only for command outbox rows created before the device-safety rollout."
        },
        "action_type": {
          "type": "string",
          "enum": ["turn_on", "turn_off", "adjust", "alert_only"]
        },
        "parameters": {
          "type": "object",
          "description": "Action-specific parameters. terra-sense also accepts a legacy JSON-encoded string for backward compatibility.",
          "additionalProperties": true
        },
        "executed_by": {
          "type": "string",
          "description": "User who approved execution of the action plan"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "specversion": "1.0",
      "type": "terra.ops.command.execute",
      "source": "//terraneuron/terra-ops",
      "id": "d4e5f6a7-b8c9-4d01-8efa-234567890abc",
      "time": "2025-12-09T10:35:00Z",
      "datacontenttype": "application/json",
      "data": {
        "trace_id": "trace-a1b2c3d4-e5f6-7890-abcd-ef1234567890",
        "plan_id": "plan-abc12345",
        "command_id": "cmd-1a2b3c4d",
        "farm_id": "farm-001",
        "target_asset_id": "fan-01",
        "target_asset_type": "device",
        "action_category": "ventilation",
        "action_type": "turn_on",
        "parameters": {
          "duration_minutes": 30,
          "speed_level": "high"
        },
        "executed_by": "operator-01"
      }
    }
  ]
}
